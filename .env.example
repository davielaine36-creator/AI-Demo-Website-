# Copy this file to .env (or set these in Vercel > Project > Settings > Environment Variables).
# All client-exposed Vite vars MUST start with VITE_.

# Contact email used by the intake + contact forms for mailto: fallbacks.
# Falls back to hello@laineindustries.co if unset.
VITE_CONTACT_EMAIL=hello@laineindustries.co

# Optional: n8n webhook URL for intake + contact form submissions.
# SERVER-ONLY — note there is NO "VITE_" prefix, so this URL is never bundled
# into the public client. The browser POSTs to the same-origin proxy at
# /api/intake (see api/intake.ts), which forwards the payload to this webhook.
# If unset, forms gracefully fall back to copy-to-clipboard + email draft.
# Set this in Vercel > Project > Settings > Environment Variables (Production).
# N8N_INTAKE_WEBHOOK_URL=https://your-n8n-instance/webhook/lane-intake

# Analytics: NO environment variable is required.
# Pageviews + custom events use Vercel Web Analytics, which is cookieless and
# zero-config — just enable "Web Analytics" in the Vercel project dashboard.
# See ANALYTICS.md for details.
